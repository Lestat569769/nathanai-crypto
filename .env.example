# ── Copy this to .env and fill in your values ─────────────────────────────
# NEVER commit .env to git

# Neo4j (auto-set by docker-compose, override if using external Neo4j)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=crypto123

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_PATH=/app/secrets/trading_wallet.json

# LLM (Ollama running on host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
PRIMARY_MODEL=qwen3:8b
GATE_MODEL=qwen3:4b

# Trading limits
MAX_POSITION_PCT=0.01
MAX_OPEN_POSITIONS=5
MIN_CONFIDENCE=0.75
SESSION_LOSS_LIMIT=0.10
DAILY_LOSS_LIMIT=0.15
MAX_DAILY_TRADES=50

# Paper trading mode (set to false for live trading)
PAPER_TRADING=true

# Smart money wallets to track (comma-separated Solana addresses)
# Add known whale / KOL wallets here
SMART_MONEY_WALLETS=

# Optional: Birdeye API key (free tier available at birdeye.so)
BIRDEYE_API_KEY=
